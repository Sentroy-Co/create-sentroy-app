{
  "name": "create-sentroy-app",
  "version": "0.1.0",
  "description": "Scaffold a Next.js app pre-wired to Sentroy Auth, Storage and Email — shadcn or Material UI.",
  "type": "module",
  "bin": {
    "create-sentroy-app": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sentroy",
    "create",
    "scaffold",
    "next",
    "auth",
    "storage",
    "email",
    "shadcn",
    "mui"
  ],
  "author": "Sentroy",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
